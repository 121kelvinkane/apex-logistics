generator client {
  provider = "prisma-client-js"  // Must be "prisma-client-js", do NOT use "prisma-client"
  // Make sure there is NO "output" field listed here
}


datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Quote {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String
  moveFrom    String
  moveTo      String
  moveDate    String
  homeSize    String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}

model Truck {
  id          Int      @id @default(autoincrement())
  plateNumber String
  model       String
  capacity    String
  status      String   @default("Available")
  createdAt   DateTime @default(now())
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  createdAt DateTime @default(now())
}

model Booking {
  id          Int      @id @default(autoincrement())
  customerName String
  origin      String
  destination String
  date        String
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}

model CompanySettings {
  id          Int      @id @default(autoincrement())
  companyName String   @default("Apex Logistics")
  email       String   @default("support@apex.com")
  phone       String   @default("+1 555 000 0000")
  address     String   @default("123 Logistics Way")
}

model Tracking {
  id            Int      @id @default(autoincrement())
  trackingId    String   @unique
  origin        String
  destination   String
  originCoords  String
  destCoords    String
  currentCoords String
  status        String   @default("In Transit")
  progress      Int      @default(0)
  lastUpdate    DateTime @default(now())
  createdAt     DateTime @default(now())
}