generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// This is our Shipment Table
model Shipment {
  id          String @id @unique // This is the Tracking ID (e.g., APX-88392)
  origin      String
  destination String
  status      String
  progress    Int    // 0 to 100
  currentLat  Float  // Latitude for the map
  currentLng  Float  // Longitude for the map
}